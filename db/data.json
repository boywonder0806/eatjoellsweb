  "about_page": {
    "headline": "About Joelle's Lounge",
    "tagline": "Fine dining rooted in community, craft, and a genuine love of great food.",
    "overview": "Joelle's Lounge was born from a simple belief: that a great meal is about more than just the food on your plate. Founded by Joelle Martin, the restaurant grew out of years of traveling, cooking, and a deep appreciation for the way a shared table can bring people together.\n\nFrom day one, we've been committed to sourcing the finest local and seasonal ingredients, partnering with nearby farms and artisan producers who share our values. Every dish on our menu tells a story — of the land it came from, the hands that prepared it, and the guests who inspired it.\n\nWhether you're celebrating a milestone, enjoying a quiet dinner for two, or gathering with friends, Joelle's Lounge is your place. We're here to make every visit feel like coming home.",
    "overview_image": "https://images.unsplash.com/photo-1559339352-11d035aa65de?auto=format&fit=crop&w=800&q=80"
  },
  "team": [
    {
      "id": 1,
      "name": "Joelle Martin",
      "role": "Founder & Owner",
      "blurb": "Joelle's vision for a warm, community-driven restaurant has guided every decision since opening day. With a background in culinary arts and hospitality management, she brings passion and precision to everything she does — from curating the menu to welcoming every guest personally.",
      "image_url": "https://www.wikihow.com/images/thumb/9/90/What_type_of_person_are_you_quiz_pic.png/728px-What_type_of_person_are_you_quiz_pic.png.webp",
      "sort_order": 0
    },
    {
      "id": 2,
      "name": "Marcus Rivera",
      "role": "Executive Chef",
      "blurb": "Chef Marcus brings over 15 years of fine dining experience to the kitchen at Joelle's Lounge. Trained in classical French technique and inspired by global flavors, he crafts seasonal menus that are bold, refined, and deeply rooted in the best local produce available.",
      "image_url": "",
      "sort_order": 1
    },
    {
      "id": 3,
      "name": "Sofia Chen",
      "role": "General Manager",
      "blurb": "Sofia ensures that every visit to Joelle's Lounge runs seamlessly from start to finish. With a sharp eye for detail and a genuine warmth for guests, she leads the front-of-house team with grace and sets the standard for hospitality across the restaurant.",
      "image_url": "",
      "sort_order": 2
    },
    {
      "id": 4,
      "name": "Daniel Brooks",
